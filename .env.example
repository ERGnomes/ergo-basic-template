# Dynamic.xyz environment ID.
#
# Create a project at https://app.dynamic.xyz/ and copy its environment ID
# from the dashboard. The same value is referenced in two ways so this
# template can be migrated to Next.js later without changing client code:
#
#   - REACT_APP_DYNAMIC_ENV_ID is what Create React App expects.
#   - NEXT_PUBLIC_DYNAMIC_ENV_ID is what a Next.js port would expect.
#
# Copy this file to `.env` (or `.env.local`) and fill in your value.
REACT_APP_DYNAMIC_ENV_ID=
NEXT_PUBLIC_DYNAMIC_ENV_ID=
