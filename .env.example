# ---------------------------------------------------------------------------
# Ergo dApp starter — environment (Create React App)
# Copy to `.env` or `.env.local` and set values before `npm start` / `npm run build`.
# See SETUP.md for full documentation.
# ---------------------------------------------------------------------------

# --- Branding (shown in navbar, document title, meta; safe defaults if unset) ---
REACT_APP_SITE_NAME=Ergo dApp starter
REACT_APP_SITE_DESCRIPTION=React starter for Ergo: wallet, gallery, and on-chain game examples you can fork.
# Optional: canonical URL for Open Graph (e.g. https://myapp.example.com)
# REACT_APP_SITE_URL=
# Optional: footer link to your fork
# REACT_APP_GITHUB_REPO_URL=https://github.com/you/your-fork

# --- Dev-only nav: Rosen / metadata demo route (`/rosen-test`). Default off for clean forks. ---
# REACT_APP_SHOW_DEV_TOOLS=true

# --- Wallet mode (how Dynamic vs Nautilus are exposed) ---
#   both | all | (empty)     — default: Dynamic + optional direct Nautilus in header
#   dynamic | dynamic-only  — Dynamic only; no direct window.ergo fallback in WalletContext
#   nautilus | nautilus-only — Nautilus-first; /dynamic route hidden
REACT_APP_WALLET_PROVIDERS=both

# --- Dynamic.xyz (email / social + embedded wallets + Nautilus in widget) ---
# From https://app.dynamic.xyz/ → your project → API → Environment ID
# Optional if REACT_APP_WALLET_PROVIDERS=nautilus-only (SDK still mounts with placeholder).
REACT_APP_DYNAMIC_ENV_ID=
# Next.js-style alias (optional); same value if you port the app later:
NEXT_PUBLIC_DYNAMIC_ENV_ID=
