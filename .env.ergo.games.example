# ---------------------------------------------------------------------------
# ERGO.games — example environment (copy to `.env` or merge into Railway)
# Full reference: docs/FORK_ERGO_GAMES.md and SETUP.md
# ---------------------------------------------------------------------------

# --- Branding (required for a distinct product) ---
REACT_APP_SITE_NAME=ERGO.games
REACT_APP_SITE_DESCRIPTION=On-chain games on Ergo — wagered tic-tac-toe and more. Unaudited example contracts; use at your own risk.
# After you have HTTPS on your real host:
REACT_APP_SITE_URL=https://ergo.games
# Your fork’s GitHub URL (footer link):
REACT_APP_GITHUB_REPO_URL=https://github.com/YOUR_ORG/ergo-games

# --- Keep production nav clean (omit or false) ---
# REACT_APP_SHOW_DEV_TOOLS=

# --- Wallet (see SETUP.md) ---
REACT_APP_WALLET_PROVIDERS=both
REACT_APP_DYNAMIC_ENV_ID=

NEXT_PUBLIC_DYNAMIC_ENV_ID=
